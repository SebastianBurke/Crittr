@page "/register"
@using Crittr.App.Services
@inject AuthService AuthService
@inject NavigationManager Nav

<PageTitle>Register — Crittr</PageTitle>

<div class="min-h-[55vh] flex items-center justify-center px-4">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Create your account</h1>
            <p class="mt-2 text-slate-600 dark:text-slate-400">Free to start — track feedings and enclosures in one place.</p>
        </div>

        <div class="rounded-2xl border border-slate-200/90 dark:border-slate-700 bg-white/90 dark:bg-gray-800/90 backdrop-blur shadow-xl shadow-slate-900/10 dark:shadow-black/30 p-6 sm:p-8">
            <p class="text-center text-sm text-slate-500 dark:text-slate-400 mb-6">
                Already registered?
                <a href="/login" class="font-semibold text-green-600 dark:text-green-400 hover:underline">Log in</a>
            </p>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="mb-5 rounded-xl bg-red-50 dark:bg-red-950/50 border border-red-200 dark:border-red-900 text-red-800 dark:text-red-200 px-4 py-3 text-sm break-words max-h-40 overflow-y-auto" role="alert">
                    @errorMessage
                </div>
            }

            @if (registered)
            {
                <div class="rounded-xl bg-green-50 dark:bg-green-950/40 border border-green-200 dark:border-green-900 text-green-900 dark:text-green-100 px-4 py-4 text-sm mb-5">
                    You’re all set. Sign in with the same email and password.
                </div>
                <a href="/login"
                   class="block w-full text-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-4 shadow-lg shadow-green-600/25 transition-colors">
                    Go to log in
                </a>
            }
            else
            {
                <div class="space-y-5">
                    <div>
                        <label for="reg-email" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Email</label>
                        <input id="reg-email" @bind="email" type="email" autocomplete="email"
                               class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-green-500/50 focus:border-green-500"/>
                    </div>
                    <div>
                        <label for="reg-password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Password</label>
                        <input id="reg-password" @bind="password" type="password" autocomplete="new-password"
                               class="w-full px-3.5 py-2.5 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 text-slate-900 dark:text-white focus:ring-2 focus:ring-green-500/50 focus:border-green-500"/>
                        <p class="mt-1.5 text-xs text-slate-500 dark:text-slate-400">Use at least 6 characters with mixed character types (Identity rules apply).</p>
                    </div>
                    <button type="button" disabled="@isBusy" @onclick="SubmitAsync"
                            class="w-full rounded-xl bg-green-600 hover:bg-green-700 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold py-3 px-4 shadow-lg shadow-green-600/25 transition-colors">
                        @(isBusy ? "Creating account…" : "Create account")
                    </button>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string? errorMessage;
    private bool registered;
    private bool isBusy;

    private async Task SubmitAsync()
    {
        errorMessage = null;
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Email and password are required.";
            return;
        }

        isBusy = true;
        try
        {
            var (ok, err) = await AuthService.RegisterAsync(email.Trim(), password);
            if (ok)
                registered = true;
            else
                errorMessage = err ?? "Registration failed.";
        }
        finally
        {
            isBusy = false;
        }
    }
}
