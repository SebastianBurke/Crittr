@page "/critter/{CritterId:int}"
@using Crittr.App.Pages.Shared.Components
@using Crittr.App.Services
@using Crittr.Shared.DTOs
@using Crittr.Shared.Models
@using Crittr.Shared.Models.Enums
@using Crittr.Shared.Utilities
@inject CritterService CritterService
@inject FeedingService FeedingService
@inject EnclosureService EnclosureService
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<PageTitle>@(critter?.Name ?? "Critter") — Crittr</PageTitle>

<div class="max-w-2xl mx-auto px-4">
    @if (!isAuthenticated)
    {
        <div class="rounded-2xl border border-slate-200 dark:border-slate-700 bg-white/80 dark:bg-gray-800/80 p-8 text-center">
            <p class="text-slate-600 dark:text-slate-400">Sign in to view this critter.</p>
            <a href="/login" class="mt-4 inline-block font-semibold text-green-600 dark:text-green-400 hover:underline">Log in</a>
        </div>
    }
    else if (isLoading)
    {
        <PageSpinner Message="Loading critter…"/>
    }
    else if (critter is null)
    {
        <div class="rounded-2xl border border-red-200 dark:border-red-900/50 bg-red-50/80 dark:bg-red-950/30 p-8 text-center">
            <p class="text-red-800 dark:text-red-200 font-medium">We couldn’t find this critter, or you don’t have access.</p>
            <a href="/" class="mt-4 inline-block text-sm font-semibold text-green-600 dark:text-green-400 hover:underline">← Back to dashboard</a>
        </div>
    }
    else
    {
        <a href="/" class="inline-flex items-center gap-1 text-sm font-medium text-green-700 dark:text-green-300 hover:underline mb-5">
            ← Dashboard
        </a>

        <!-- Critter header card -->
        <div class="rounded-2xl border border-slate-200/90 dark:border-slate-700 bg-white/90 dark:bg-gray-800/80 backdrop-blur p-5 sm:p-7 shadow-xl shadow-slate-900/5 dark:shadow-black/20 mb-6">
            <div class="flex gap-4 items-center">
                <img src="@AppAssets.Resolve(critter.IconUrl)" alt="" class="w-20 h-20 sm:w-24 sm:h-24 rounded-2xl border border-green-200/60 dark:border-green-900/50 shadow-md shrink-0"/>
                <div class="min-w-0">
                    <h1 class="text-2xl sm:text-3xl font-bold tracking-tight text-slate-900 dark:text-white">@critter.Name</h1>
                    <p class="text-base text-slate-600 dark:text-slate-300 mt-0.5">@critter.Species</p>
                    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">
                        Last fed: <span class="font-medium text-slate-700 dark:text-slate-200">@(critter.LastFeedingDate?.ToShortDateString() ?? "Never")</span>
                    </p>
                </div>
            </div>
        </div>

        @if (critter.EnclosureProfileId is null)
        {
            var requiresLabel = EnclosureCompatibility.GetEnclosureRequirementLabel(critter.SpeciesType);
            <div class="mb-5 rounded-xl border border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950/30 px-4 py-3 flex items-center justify-between gap-3">
                <div class="min-w-0">
                    <p class="text-sm font-semibold text-amber-800 dark:text-amber-200">@critter.Name needs @requiresLabel</p>
                    <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">No enclosure assigned — assign or create one on the dashboard.</p>
                </div>
                <a href="/" class="text-sm font-semibold text-amber-700 dark:text-amber-300 hover:underline shrink-0">Go to dashboard →</a>
            </div>
        }
        else if (enclosureDto is not null)
        {
            var compatible = EnclosureCompatibility.IsCompatible(critter.SpeciesType, enclosureDto.EnclosureType);
            <div class="mb-5 rounded-xl border @(compatible ? "border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-950/20" : "border-amber-200 dark:border-amber-800 bg-amber-50 dark:bg-amber-950/20") px-4 py-3 flex items-center justify-between gap-3">
                <div class="min-w-0">
                    @if (compatible)
                    {
                        <p class="text-sm font-medium text-green-800 dark:text-green-200">
                            ✓ Compatible with
                            <a href="@($"/enclosure/{enclosureDto.Id}")" class="font-semibold hover:underline">@enclosureDto.Name</a>
                            <span class="text-green-600 dark:text-green-400 font-normal ml-1">(@EnclosureCompatibility.FormatEnclosureType(enclosureDto.EnclosureType))</span>
                        </p>
                    }
                    else
                    {
                        <p class="text-sm font-medium text-amber-800 dark:text-amber-200">
                            ⚠ <a href="@($"/enclosure/{enclosureDto.Id}")" class="font-semibold hover:underline">@enclosureDto.Name</a> may not be ideal for a @critter.SpeciesType
                        </p>
                        <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5">Consider @EnclosureCompatibility.GetEnclosureRequirementLabel(critter.SpeciesType).</p>
                    }
                </div>
                <a href="@($"/enclosure/{enclosureDto.Id}")" class="text-xs font-medium text-slate-500 dark:text-slate-400 hover:underline shrink-0">View enclosure →</a>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(formError))
        {
            <div class="mb-5 rounded-xl bg-red-50 dark:bg-red-950/40 border border-red-200 dark:border-red-900 text-red-800 dark:text-red-200 px-4 py-3 text-sm" role="alert">
                @formError
            </div>
        }

        <!-- Log a feeding -->
        <section class="mb-8 rounded-2xl border border-slate-200/90 dark:border-slate-700 bg-white/90 dark:bg-gray-800/80 p-5 sm:p-7 shadow-lg shadow-slate-900/5">
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-1">Log a feeding</h2>
            <p class="text-sm text-slate-500 dark:text-slate-400 mb-5">Keep a clear history for you and your vet.</p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="sm:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Date</label>
                    <input type="date" @bind="newFeedingDate"
                           class="w-full rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 px-3.5 py-2.5 text-slate-900 dark:text-white focus:ring-2 focus:ring-green-500/40 focus:border-green-500 outline-none"/>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Food offered</label>
                    <input @bind="newFoodItem" placeholder="e.g. Dubia roaches, fuzzy mouse"
                           class="w-full rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 px-3.5 py-2.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:ring-2 focus:ring-green-500/40 focus:border-green-500 outline-none"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Quantity</label>
                    <input type="number" step="0.5" @bind="newQuantity"
                           class="w-full rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 px-3.5 py-2.5 text-slate-900 dark:text-white focus:ring-2 focus:ring-green-500/40 focus:border-green-500 outline-none"/>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">Food type</label>
                    <select @bind="newItemType"
                            class="w-full rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 px-3.5 py-2.5 text-slate-900 dark:text-white focus:ring-2 focus:ring-green-500/40 focus:border-green-500 outline-none">
                        @foreach (var t in Enum.GetValues<ItemType>())
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                </div>
                <div class="sm:col-span-2 flex items-center gap-3">
                    <input type="checkbox" id="eaten" @bind="newWasEaten"
                           class="w-4 h-4 rounded border-slate-300 text-green-600 focus:ring-green-500"/>
                    <label for="eaten" class="text-sm text-slate-700 dark:text-slate-300">Consumed successfully</label>
                </div>
                <div class="sm:col-span-2">
                    <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1.5">
                        Notes <span class="text-slate-400 font-normal">(optional)</span>
                    </label>
                    <textarea @bind="newNotes" rows="2" placeholder="Behavior, leftovers, refusal notes…"
                              class="w-full rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-900 px-3.5 py-2.5 text-slate-900 dark:text-white placeholder:text-slate-400 focus:ring-2 focus:ring-green-500/40 focus:border-green-500 outline-none resize-none"></textarea>
                </div>
            </div>

            <button type="button" disabled="@isSaving" @onclick="SaveFeedingAsync"
                    class="mt-5 w-full sm:w-auto rounded-xl bg-green-600 hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed text-white font-semibold px-6 py-2.5 shadow-lg shadow-green-600/20 transition-colors">
                @(isSaving ? "Saving…" : "Save feeding")
            </button>
        </section>

        <!-- Feeding history -->
        <section>
            <h2 class="text-lg font-semibold text-slate-900 dark:text-white mb-4">Feeding history</h2>
            @if (feedings.Count == 0)
            {
                <p class="text-sm text-slate-500 dark:text-slate-400 rounded-xl border border-dashed border-slate-300 dark:border-slate-600 px-4 py-8 text-center">
                    No entries yet. Log your first feeding above.
                </p>
            }
            else
            {
                @foreach (var group in feedings
                    .GroupBy(f => new { f.FeedingDate.Year, f.FeedingDate.Month })
                    .OrderByDescending(g => g.Key.Year).ThenByDescending(g => g.Key.Month))
                {
                    <div class="mb-6">
                        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500 mb-2">
                            @(new DateTime(group.Key.Year, group.Key.Month, 1).ToString("MMMM yyyy"))
                        </p>
                        <ul class="space-y-2">
                            @foreach (var f in group.OrderByDescending(x => x.FeedingDate))
                            {
                                <li class="rounded-xl border border-slate-200 dark:border-slate-700 bg-white/80 dark:bg-gray-800/60 px-4 py-3.5">
                                    <div class="flex items-start justify-between gap-3">
                                        <div class="min-w-0">
                                            <p class="font-semibold text-slate-900 dark:text-white text-sm">@f.FeedingDate.ToString("MMM d")</p>
                                            <p class="text-sm text-slate-600 dark:text-slate-300 mt-0.5 break-words">
                                                @f.FoodItem · @f.Quantity× @f.ItemTypeString
                                            </p>
                                            @if (!string.IsNullOrWhiteSpace(f.Notes))
                                            {
                                                <p class="text-xs text-slate-500 dark:text-slate-400 mt-1">@f.Notes</p>
                                            }
                                            @if (!f.WasEaten)
                                            {
                                                <p class="text-xs text-amber-700 dark:text-amber-300 mt-1">Refused or partial</p>
                                            }
                                        </div>
                                        <div class="shrink-0">
                                            @if (deletingId == f.Id)
                                            {
                                                <div class="flex gap-2 items-center">
                                                    <button type="button" @onclick="() => ConfirmDeleteAsync(f.Id)"
                                                            class="text-xs font-semibold text-red-600 dark:text-red-400 hover:underline">
                                                        Yes, remove
                                                    </button>
                                                    <button type="button" @onclick="CancelDelete"
                                                            class="text-xs text-slate-500 dark:text-slate-400 hover:underline">
                                                        Cancel
                                                    </button>
                                                </div>
                                            }
                                            else
                                            {
                                                <button type="button" @onclick="() => RequestDelete(f.Id)"
                                                        class="text-sm font-medium text-slate-400 hover:text-red-500 dark:hover:text-red-400 transition-colors">
                                                    Remove
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </li>
                            }
                        </ul>
                    </div>
                }
            }
        </section>
    }
</div>

@code {
    [Parameter] public int CritterId { get; set; }

    private bool isAuthenticated;
    private bool isLoading = true;
    private bool isSaving;
    private CritterDto? critter;
    private EnclosureProfileDto? enclosureDto;
    private List<FeedingRecordDto> feedings = new();
    private string? formError;
    private int? deletingId;

    private DateTime newFeedingDate = DateTime.Today;
    private string newFoodItem = "";
    private double newQuantity = 1;
    private ItemType newItemType = ItemType.Insect;
    private bool newWasEaten = true;
    private string? newNotes;

    protected override async Task OnInitializedAsync()
    {
        isAuthenticated = await LocalStorage.ContainKeyAsync("authToken");
        if (!isAuthenticated)
            isLoading = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!isAuthenticated)
        {
            isLoading = false;
            return;
        }

        isLoading = true;
        await LoadAsync();
        isLoading = false;
    }

    private async Task LoadAsync()
    {
        formError = null;
        critter = await CritterService.GetDtoByIdAsync(CritterId);
        if (critter is null)
        {
            feedings.Clear();
            enclosureDto = null;
            return;
        }

        feedings = await FeedingService.GetByCritterIdAsync(CritterId);

        if (critter.EnclosureProfileId.HasValue)
            enclosureDto = await EnclosureService.GetEnclosureByIdAsync(critter.EnclosureProfileId.Value);
        else
            enclosureDto = null;
    }

    private async Task SaveFeedingAsync()
    {
        if (critter is null) return;
        if (string.IsNullOrWhiteSpace(newFoodItem))
        {
            formError = "Enter what food was offered.";
            return;
        }

        isSaving = true;
        formError = null;
        try
        {
            var record = new FeedingRecord
            {
                CritterId = critter.Id,
                FeedingDate = newFeedingDate.Date,
                FoodItem = newFoodItem.Trim(),
                Quantity = newQuantity,
                ItemType = newItemType,
                WasEaten = newWasEaten,
                Notes = string.IsNullOrWhiteSpace(newNotes) ? null : newNotes.Trim()
            };

            var created = await FeedingService.CreateAsync(record);
            if (created is null)
            {
                formError = "Could not save. Try logging in again.";
                return;
            }

            newFoodItem = "";
            newQuantity = 1;
            newNotes = null;
            newFeedingDate = DateTime.Today;
            await LoadAsync();
            StateHasChanged();
        }
        finally
        {
            isSaving = false;
        }
    }

    private void RequestDelete(int id) { deletingId = id; StateHasChanged(); }
    private void CancelDelete() { deletingId = null; StateHasChanged(); }

    private async Task ConfirmDeleteAsync(int id)
    {
        deletingId = null;
        if (!await FeedingService.DeleteAsync(id))
            formError = "Could not remove that entry.";
        else
            await LoadAsync();
    }
}
