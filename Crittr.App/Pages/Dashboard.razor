@page "/"
@using Crittr.App.Pages.Shared.Components
@using Crittr.App.Services
@using Crittr.Shared.DTOs
@using Crittr.Shared.Models.Enums
@using Crittr.Shared.Utilities
@inject CritterService CritterService
@inject EnclosureService EnclosureService
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<PageTitle>Dashboard — Crittr</PageTitle>

<div class="relative w-full min-w-0">
    @if (isLoading)
    {
        <PageSpinner Message="Loading your enclosures…"/>
    }
    else if (!isAuthenticated)
    {
        <div class="max-w-sm sm:max-w-lg mx-auto text-center py-10 sm:py-16 px-2">
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Your vivarium, organized</h1>
            <p class="mt-3 text-slate-600 dark:text-slate-400 leading-relaxed">
                Log in to see enclosures, critters, and feeding history in one calm dashboard.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/login"
                   class="inline-flex justify-center items-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 shadow-lg transition-colors">
                    Log in
                </a>
                <a href="/register"
                   class="inline-flex justify-center items-center rounded-xl bg-slate-100 border border-slate-300 text-slate-800 font-semibold px-6 py-3 shadow-sm hover:bg-slate-200 transition-colors">
                    Create account
                </a>
            </div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="max-w-xl mx-auto mb-4 rounded-xl border border-amber-200 bg-amber-50 text-amber-900 px-4 py-3 text-sm" role="alert">
                @loadError
            </div>
        }

        <div class="w-full max-w-5xl mx-auto min-w-0">
        <div class="lg:flex lg:gap-8 lg:items-start">

        <!-- LEFT: Enclosure carousel (primary focus) -->
        <div class="w-full min-w-0 lg:flex-1">

        <!-- Arrows live outside the overflow container so they aren't clipped -->
        <div class="relative w-full">

            @if (currentCardIndex > 0)
            {
                <button type="button"
                        aria-label="Previous"
                        class="absolute left-0 top-1/2 -translate-y-1/2 z-20
                               w-8 h-8 flex items-center justify-center
                               rounded-full bg-white border border-slate-200 shadow-md
                               hover:bg-slate-50 transition-colors"
                        @onclick="PrevSlide">
                    <svg class="w-4 h-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
            }

            @if (currentCardIndex < enclosures.Count)
            {
                <button type="button"
                        aria-label="Next"
                        class="absolute right-0 top-1/2 -translate-y-1/2 z-20
                               w-8 h-8 flex items-center justify-center
                               rounded-full bg-white border border-slate-200 shadow-md
                               hover:bg-slate-50 transition-colors"
                        @onclick="NextSlide">
                    <svg class="w-4 h-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            }

            <!-- Clipping container — no padding here -->
            <div class="overflow-hidden w-full"
                 @ontouchstart="OnTouchStart"
                 @ontouchend="OnTouchEnd">

                <!-- Slide track: translateX moves by multiples of the container width -->
                <div class="flex w-full transition-transform duration-300 ease-out"
                     style="@($"transform: translateX(-{currentCardIndex * 100}%)")">

                    @foreach (var enclosure in enclosures)
                    {
                        <!-- min-w-full resolves against the overflow container (block ancestor), not the flex parent -->
                        <div class="w-full shrink-0">
                            <div class="mx-auto px-4 sm:px-8">
                                <div class="rounded-2xl sm:rounded-3xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-gray-900 shadow-xl sm:shadow-2xl overflow-hidden"
                                     data-drop-zone
                                     @ondragover:preventDefault
                                     @ondragover="HandleDragOver"
                                     @ondragenter="() => OnDragEnter(enclosure.Id)"
                                     @ondragleave="() => OnDragLeave(enclosure.Id)"
                                     @ondrop="() => OnDropCritter(enclosure)">

                                    <!-- Header bar — entire section is a link to enclosure detail -->
                                    <a href="@($"/enclosure/{enclosure.Id}")"
                                       class="block px-4 sm:px-6 pt-4 sm:pt-6 pb-3 transition-colors group">
                                        <p class="text-lg sm:text-2xl font-bold text-slate-900 dark:text-white tracking-tight truncate group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors">@enclosure.Name</p>
                                        <p class="text-xs sm:text-sm text-slate-400 mt-0.5">@EnclosureCompatibility.FormatEnclosureType(enclosure.EnclosureType)</p>
                                    </a>

                                    <!-- Critter canvas — full bleed, tall -->
                                    @{
                                        var enclosureCritters = critters.Where(r => r.EnclosureProfileId == enclosure.Id).ToList();
                                    }
                                    <div class="relative w-full overflow-hidden bg-gradient-to-b @EnclosureTheme.CanvasBg(enclosure.EnclosureType) border-t @EnclosureTheme.CanvasBorder(enclosure.EnclosureType)"
                                         style="aspect-ratio: 2 / 1;"
                                         data-critter-canvas>
                                        @EnclosureTheme.CanvasOverlay(enclosure.EnclosureType)

                                        @* Drag-and-drop overlay *@
                                        @if (draggingCritter != null)
                                        {
                                            var canDrop = EnclosureCompatibility.IsCompatible(draggingCritter.SpeciesType, enclosure.EnclosureType);
                                            var isHovered = dropTargetEnclosureId == enclosure.Id;
                                            @if (isHovered && canDrop)
                                            {
                                                <div class="absolute inset-0 z-10 flex items-center justify-center bg-green-500/10 animate-pulse pointer-events-none">
                                                    <div class="bg-white/95 dark:bg-gray-900/95 rounded-xl px-4 py-2 shadow-lg border border-green-200 dark:border-green-700">
                                                        <p class="text-sm font-semibold text-green-700 dark:text-green-400">Drop to add @draggingCritter.Name ✓</p>
                                                    </div>
                                                </div>
                                            }
                                            else if (isHovered && !canDrop)
                                            {
                                                <div class="absolute inset-0 z-10 flex items-center justify-center bg-red-500/5 pointer-events-none">
                                                    <div class="bg-white/95 dark:bg-gray-900/95 rounded-xl px-4 py-2 shadow-lg border border-red-200 dark:border-red-800">
                                                        <p class="text-sm font-semibold text-red-600 dark:text-red-400">Not compatible</p>
                                                    </div>
                                                </div>
                                            }
                                            else if (canDrop)
                                            {
                                                <div class="absolute inset-0 z-10 border-2 border-green-400/50 animate-pulse pointer-events-none" />
                                            }
                                        }

                                        @if (enclosureCritters.Count == 0)
                                        {
                                            <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 px-4 text-center">
                                                <p class="text-slate-400 text-sm">No critters here yet.</p>
                                                <a href="@($"/enclosure/{enclosure.Id}")"
                                                   class="text-xs text-green-600 dark:text-green-400 font-medium hover:underline">
                                                    Open enclosure to add one →
                                                </a>
                                            </div>
                                        }
                                        @foreach (var critter in enclosureCritters)
                                        {
                                            <a href="@($"/critter/{critter.Id}")"
                                               class="absolute group focus:outline-none rounded-lg transition-transform hover:scale-110"
                                               style="top:@(GetCritterPosition(critter.Id).top)%; left:@(GetCritterPosition(critter.Id).left)%;">
                                                <div class="relative" id="critter-@critter.Id">
                                                    <img src="@AppAssets.Resolve(critter.IconUrl)"
                                                         class="w-16 h-16 drop-shadow-lg"
                                                         alt="@critter.Name"/>
                                                    @if (critter.Condition == CritterCondition.Unknown)
                                                    {
                                                        <span class="absolute -bottom-1 -right-1 text-sm leading-none select-none font-bold text-slate-400/80 drop-shadow-sm"
                                                              title="Not yet assessed">?</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="absolute -bottom-1 -right-1 text-sm leading-none select-none drop-shadow"
                                                              title="@ConditionLabel(critter.Condition)">
                                                            @ConditionEmoji(critter.Condition)
                                                        </span>
                                                    }
                                                </div>
                                            </a>
                                        }
                                    </div>

                                </div>
                            </div>
                        </div>
                    }

                    <!-- Final slide: Add enclosure or critter -->
                    <div class="min-w-full">
                        <div class="mx-auto px-4 sm:px-8">
                            <div class="rounded-3xl border-2 border-dashed border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-950/20 flex flex-col items-center justify-center text-center gap-4"
                                 style="aspect-ratio: 2 / 1;">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800 dark:text-white">Add something new</h3>
                                    <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Swipe back to browse your existing enclosures.</p>
                                </div>
                                <div class="flex flex-col sm:flex-row gap-3">
                                    <button type="button"
                                            class="rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 shadow-md transition-colors"
                                            @onclick="ShowAddEnclosureModal">
                                        + Create enclosure
                                    </button>
                                    <button type="button"
                                            class="rounded-xl border border-green-400 dark:border-green-700 bg-white dark:bg-gray-900 text-green-700 dark:text-green-400 font-semibold px-6 py-3 shadow-sm hover:bg-green-50 dark:hover:bg-green-950/30 transition-colors"
                                            @onclick="() => showCritterModal = true">
                                        + Add critter
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Carousel dots -->
        @if (enclosures.Count > 0)
        {
            <nav class="flex items-center justify-center gap-2 mt-5" aria-label="Enclosure navigation">
                @for (int i = 0; i <= enclosures.Count; i++)
                {
                    int index = i;
                    bool isActive = index == currentCardIndex;
                    bool isAddSlide = i == enclosures.Count;
                    <button type="button"
                            aria-label="@(isAddSlide ? "Add" : enclosures[i].Name)"
                            class="@(isActive ? "w-3 h-3 rounded-full bg-green-600" : isAddSlide ? "w-2.5 h-2.5 rounded-full bg-green-200 border border-green-400" : "w-2.5 h-2.5 rounded-full bg-slate-300 hover:bg-slate-400") transition-all"
                            @onclick="() => NavigateToCard(index)">
                    </button>
                }
            </nav>
            @if (currentCardIndex == enclosures.Count)
            {
                <p class="text-center text-xs text-slate-400 mt-1">Swipe back to browse</p>
            }
        }

        </div><!-- end LEFT column -->

        <!-- RIGHT: Homeless critters sidebar (drag onto an enclosure to assign) -->
        @if (critters.Any(c => c.EnclosureProfileId == null))
        {
            <div class="mt-8 lg:mt-0 lg:w-72 lg:shrink-0">
                <div class="rounded-2xl border border-amber-200 bg-amber-50 dark:bg-amber-950/20 dark:border-amber-800 p-4">
                    <h2 class="text-sm font-semibold text-amber-900 dark:text-amber-200">Without an enclosure</h2>
                    <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5 mb-3">Critters without a home yet. Drag one onto a compatible enclosure to assign it, or tap to open their profile.</p>

                    <div class="grid grid-cols-3 gap-2.5 lg:grid-cols-1 lg:gap-2.5">
                        @foreach (var critter in critters.Where(c => c.EnclosureProfileId == null))
                        {
                            var fits    = FitsCurrentEnclosure(critter);
                            var focused = FocusedEnclosure != null;
                            var cardBorder = fits    ? "border-green-400 dark:border-green-500"
                                           : focused ? "border-slate-200 dark:border-slate-700 opacity-40 grayscale"
                                                     : "border-amber-200 dark:border-amber-800";
                            <div class="relative rounded-xl border bg-white dark:bg-gray-900 p-2.5 cursor-grab active:cursor-grabbing transition-all select-none text-center @cardBorder"
                                 draggable="true"
                                 @ondragstart="() => OnDragStart(critter)"
                                 @ondragend="OnDragEnd"
                                 @onclick="() => GoToCritter(critter.Id)">
                                @if (fits)
                                {
                                    <div class="absolute inset-0 rounded-xl ring-2 ring-green-400/60 dark:ring-green-500/50 animate-pulse pointer-events-none" />
                                }
                                <img src="@AppAssets.Resolve(critter.IconUrl)" alt="" class="w-10 h-10 rounded-lg mx-auto mb-1.5 pointer-events-none"/>
                                <p class="font-semibold text-slate-900 dark:text-white text-xs truncate">@critter.Name</p>
                                <p class="text-[10px] text-slate-500 dark:text-slate-400 truncate">@critter.Species</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        </div><!-- end two-column flex -->
        </div><!-- end max-w-5xl -->
    }
</div>

@* Tooltip cards rendered at root level — outside every overflow:hidden and CSS-transformed ancestor *@
@if (isAuthenticated && !isLoading)
{
    @foreach (var critter in critters)
    {
        <div id="tooltip-@critter.Id"
             class="fixed z-40 w-44 bg-white text-slate-900 text-xs p-2.5 rounded-xl shadow-xl pointer-events-none border border-slate-100 transition-opacity duration-200 opacity-0 hidden sm:block"
             style="top:0;left:-9999px;">
            <span class="font-semibold block text-sm">@critter.Name</span>
            <span class="text-slate-500 text-xs block">@critter.Species</span>
            @if (critter.Condition != CritterCondition.Unknown)
            {
                <span class="block mt-1 text-xs font-medium @ConditionTextClass(critter.Condition)">
                    @ConditionEmoji(critter.Condition) @ConditionLabel(critter.Condition)
                </span>
            }
            @if (critter.LastFeedingDate is { } d && d.Year >= 2000)
            {
                <span class="block mt-1 text-green-700 text-xs">Last fed: @d.ToShortDateString()</span>
            }
            <span class="text-green-600 font-medium text-xs mt-1 block">Tap to open →</span>
        </div>
    }
}

<CreateEnclosureModal IsVisible="showEnclosureModal"
                      IsVisibleChanged="HandleEnclosureModalVisibilityChanged"
                      OnEnclosureCreated="HandleEnclosureCreated"
                      PreferredEnclosureType="preferredEnclosureType"
                      CompatibleEnclosureTypes="pendingCompatibleTypes"
                      RecommendedForLabel="@recommendedForLabel"/>

<AddCritterModal IsVisible="showCritterModal"
                 IsVisibleChanged="v => { showCritterModal = v; StateHasChanged(); }"
                 OnCritterAdded="HandleCritterAdded"
                 EnclosureId="0"
                 EnclosureName=""/>

@code {
    private bool isLoading = true;
    private bool isAuthenticated;
    private List<EnclosureProfileDto> enclosures = new();
    private List<CritterDto> critters = new();
    private List<CritterDto> pendingCritters = new();
    private DotNetObjectReference<Dashboard>? dotNetHelper;
    private int currentCardIndex;
    private string? loadError;

    private bool showEnclosureModal;
    private EnclosureType? preferredEnclosureType;
    private string? recommendedForLabel;
    private IReadOnlyList<EnclosureType>? pendingCompatibleTypes;

    private bool showCritterModal;

    // Drag-and-drop state
    private CritterDto? draggingCritter;
    private int? dropTargetEnclosureId;
    private int _dragEnterCount;

    private double _touchStartX;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isAuthenticated = await localStorage.ContainKeyAsync("authToken");
            if (isAuthenticated)
                await LoadData();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void PrevSlide() => NavigateToCard(currentCardIndex - 1);
    private void NextSlide() => NavigateToCard(currentCardIndex + 1);

    private void OnTouchStart(TouchEventArgs e) => _touchStartX = e.Touches[0].ClientX;

    private void OnTouchEnd(TouchEventArgs e)
    {
        var delta = _touchStartX - e.ChangedTouches[0].ClientX;
        int total = enclosures.Count + 1;
        if (delta > 50 && currentCardIndex < total - 1) NavigateToCard(currentCardIndex + 1);
        else if (delta < -50 && currentCardIndex > 0) NavigateToCard(currentCardIndex - 1);
    }

    private async Task LoadData()
    {
        loadError = null;
        try
        {
            enclosures = await EnclosureService.GetEnclosuresAsync();
            critters.Clear();

            foreach (var enc in enclosures)
                critters.AddRange(await CritterService.GetCrittersByEnclosureIdAsync(enc.Id));

            var unassigned = await CritterService.GetUnassignedCrittersAsync();
            critters.AddRange(unassigned);

            var storedId = await localStorage.GetItemAsync<int>("crittr_last_enc");
            if (storedId > 0)
            {
                var idx = enclosures.FindIndex(e => e.Id == storedId);
                if (idx >= 0) currentCardIndex = idx;
            }

            if (currentCardIndex > enclosures.Count)
                currentCardIndex = enclosures.Count;
        }
        catch (UnauthorizedAccessException)
        {
            loadError = "Your session may have expired. Please log in again.";
        }
        catch
        {
            loadError = "Could not load data. Check your connection and that the API is running.";
        }
    }

    private void NavigateToCard(int index)
    {
        int total = enclosures.Count + 1;
        if (index >= 0 && index < total)
        {
            currentCardIndex = index;
            if (index < enclosures.Count)
                _ = localStorage.SetItemAsync("crittr_last_enc", enclosures[index].Id);
            StateHasChanged();
        }
    }

    private void ShowAddEnclosureModal() { showEnclosureModal = true; StateHasChanged(); }

    private Task HandleEnclosureModalVisibilityChanged(bool visible)
    {
        showEnclosureModal = visible;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleEnclosureCreated(EnclosureProfileDto newEnclosure)
    {
        foreach (var draft in pendingCritters)
        {
            draft.EnclosureProfileId = newEnclosure.Id;
            await CritterService.CreateCritterAsync(draft);
        }
        pendingCritters.Clear();
        preferredEnclosureType = null;
        pendingCompatibleTypes = null;
        recommendedForLabel = null;
        await LoadData();
        currentCardIndex = enclosures.FindIndex(e => e.Id == newEnclosure.Id);
        if (currentCardIndex < 0) currentCardIndex = Math.Max(0, enclosures.Count - 1);
        showEnclosureModal = false;
        StateHasChanged();
    }

    private async Task HandleCritterAdded(CritterDto critter)
    {
        showCritterModal = false;
        await LoadData();
        StateHasChanged();
    }

    private void GoToCritter(int critterId) => NavigationManager.NavigateTo("/critter/" + critterId);

    private void PromptEnclosureForCritter(CritterDto homelessCritter)
    {
        pendingCritters.Add(homelessCritter);
        pendingCompatibleTypes = EnclosureCompatibility.GetCompatibleEnclosureTypes(homelessCritter.SpeciesType);
        preferredEnclosureType = null;
        recommendedForLabel = homelessCritter.Name;
        showEnclosureModal = true;
    }

    // ── Enclosure focus helpers ────────────────────────────────────────────────

    private EnclosureProfileDto? FocusedEnclosure =>
        currentCardIndex < enclosures.Count ? enclosures[currentCardIndex] : null;

    private bool FitsCurrentEnclosure(CritterDto critter) =>
        FocusedEnclosure is { } enc &&
        EnclosureCompatibility.IsCompatible(critter.SpeciesType, enc.EnclosureType);

    // ── Drag-and-drop ──────────────────────────────────────────────────────────

    // Persisted alongside draggingCritter so OnDropCritter can read them even
    // if OnDragEnd fires and nulls draggingCritter before the drop task runs.
    private int _dragCritterId;
    private SpeciesType _dragCritterSpecies;

    private void HandleDragOver(DragEventArgs _) { }  // empty handler — required for @ondragover:preventDefault to register

    private void OnDragStart(CritterDto critter)
    {
        draggingCritter = critter;
        _dragCritterId = critter.Id;
        _dragCritterSpecies = critter.SpeciesType;
        dropTargetEnclosureId = null;
        _dragEnterCount = 0;
        StateHasChanged();
    }

    private void OnDragEnd()
    {
        draggingCritter = null;
        dropTargetEnclosureId = null;
        _dragEnterCount = 0;
        StateHasChanged();
    }

    private void OnDragEnter(int enclosureId)
    {
        if (dropTargetEnclosureId != enclosureId) _dragEnterCount = 0;
        dropTargetEnclosureId = enclosureId;
        _dragEnterCount++;
        StateHasChanged();
    }

    private void OnDragLeave(int enclosureId)
    {
        if (dropTargetEnclosureId != enclosureId) return;
        _dragEnterCount--;
        if (_dragEnterCount <= 0) { dropTargetEnclosureId = null; _dragEnterCount = 0; }
        StateHasChanged();
    }

    private async Task OnDropCritter(EnclosureProfileDto enclosure)
    {
        // Use the persistent fields — draggingCritter may already be null if
        // OnDragEnd fired before this async handler was scheduled.
        var critterId = _dragCritterId;
        var critterSpecies = _dragCritterSpecies;
        if (critterId == 0) return;

        draggingCritter = null;
        dropTargetEnclosureId = null;
        _dragEnterCount = 0;
        _dragCritterId = 0;

        if (!EnclosureCompatibility.IsCompatible(critterSpecies, enclosure.EnclosureType)) return;
        var success = await CritterService.AssignEnclosureAsync(critterId, enclosure.Id);
        if (!success) loadError = "Could not assign critter. Try again.";
        await LoadData();
        StateHasChanged();
    }

    // ─────────────────────────────────────────────────────────────────────────

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            dotNetHelper = DotNetObjectReference.Create(this);

        if (!isLoading && isAuthenticated && enclosures.Count > 0)
        {
            try { await JSRuntime.InvokeVoidAsync("initDropZones"); } catch { }

            if (currentCardIndex < enclosures.Count)
            {
                var ids = critters
                    .Where(r => r.EnclosureProfileId == enclosures[currentCardIndex].Id)
                    .Select(r => $"critter-{r.Id}")
                    .ToArray();
                if (ids.Length > 0)
                {
                    await JSRuntime.InvokeVoidAsync("animateAllCritters", (object)ids);
                    await JSRuntime.InvokeVoidAsync("initCritterTooltips", (object)ids);
                }
            }
        }
    }

    private readonly Dictionary<int, (int top, int left)> _critterPositions = new();

    private (int top, int left) GetCritterPosition(int critterId)
    {
        if (!_critterPositions.TryGetValue(critterId, out var pos))
        {
            var rng = new Random(critterId);
            pos = (rng.Next(8, 72), rng.Next(8, 72));
            _critterPositions[critterId] = pos;
        }
        return pos;
    }

    private static string ConditionEmoji(CritterCondition condition) => condition switch
    {
        CritterCondition.Thriving  => "😊",
        CritterCondition.Good      => "🙂",
        CritterCondition.Fair      => "😐",
        CritterCondition.Attention => "⚠️",
        CritterCondition.Critical  => "🚨",
        _                          => "?"
    };

    private static string ConditionLabel(CritterCondition condition) => condition switch
    {
        CritterCondition.Thriving  => "Thriving",
        CritterCondition.Good      => "Good",
        CritterCondition.Fair      => "Fair",
        CritterCondition.Attention => "Needs attention",
        CritterCondition.Critical  => "Critical",
        _                          => "Not yet assessed"
    };

    private static string ConditionTextClass(CritterCondition condition) => condition switch
    {
        CritterCondition.Thriving  => "text-green-600",
        CritterCondition.Good      => "text-green-500",
        CritterCondition.Fair      => "text-amber-500",
        CritterCondition.Attention => "text-orange-600",
        CritterCondition.Critical  => "text-red-600",
        _                          => "text-slate-400"
    };

}
