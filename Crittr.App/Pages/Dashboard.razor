@page "/"
@using Crittr.App.Pages.Shared.Components
@using Crittr.App.Services
@using Crittr.Shared.DTOs
@using Crittr.Shared.Models.Enums
@inject CritterService CritterService
@inject EnclosureService EnclosureService
@inject Blazored.LocalStorage.ILocalStorageService localStorage
@inject IJSRuntime JSRuntime

<PageTitle>Dashboard — Crittr</PageTitle>

<div class="relative w-full min-w-0">
    @if (isLoading)
    {
        <PageSpinner Message="Loading your enclosures…"/>
    }
    else if (!isAuthenticated)
    {
        <div class="max-w-sm sm:max-w-lg mx-auto text-center py-10 sm:py-16 px-2">
            <h1 class="text-3xl font-bold tracking-tight text-slate-900 dark:text-white">Your vivarium, organized</h1>
            <p class="mt-3 text-slate-600 dark:text-slate-400 leading-relaxed">
                Log in to see enclosures, critters, and feeding history in one calm dashboard.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/login"
                   class="inline-flex justify-center items-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 shadow-lg transition-colors">
                    Log in
                </a>
                <a href="/register"
                   class="inline-flex justify-center items-center rounded-xl bg-slate-100 border border-slate-300 text-slate-800 font-semibold px-6 py-3 shadow-sm hover:bg-slate-200 transition-colors">
                    Create account
                </a>
            </div>
        </div>
    }
    else
    {
        @if (!string.IsNullOrEmpty(loadError))
        {
            <div class="max-w-xl mx-auto mb-4 rounded-xl border border-amber-200 bg-amber-50 text-amber-900 px-4 py-3 text-sm" role="alert">
                @loadError
            </div>
        }

        <div class="w-full max-w-5xl mx-auto min-w-0">
        <div class="lg:flex lg:gap-8 lg:items-start">

        <!-- LEFT: Enclosure carousel (primary focus) -->
        <div class="w-full min-w-0 lg:flex-1">

        <!-- Arrows live outside the overflow container so they aren't clipped -->
        <div class="relative w-full">

            @if (currentCardIndex > 0)
            {
                <button type="button"
                        aria-label="Previous"
                        class="absolute left-0 top-1/2 -translate-y-1/2 z-20
                               w-8 h-8 flex items-center justify-center
                               rounded-full bg-white border border-slate-200 shadow-md
                               hover:bg-slate-50 transition-colors"
                        @onclick="PrevSlide">
                    <svg class="w-4 h-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
            }

            @if (currentCardIndex < enclosures.Count)
            {
                <button type="button"
                        aria-label="Next"
                        class="absolute right-0 top-1/2 -translate-y-1/2 z-20
                               w-8 h-8 flex items-center justify-center
                               rounded-full bg-white border border-slate-200 shadow-md
                               hover:bg-slate-50 transition-colors"
                        @onclick="NextSlide">
                    <svg class="w-4 h-4 text-slate-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                    </svg>
                </button>
            }

            <!-- Clipping container — no padding here -->
            <div class="overflow-hidden w-full"
                 @ontouchstart="OnTouchStart"
                 @ontouchend="OnTouchEnd">

                <!-- Slide track: translateX moves by multiples of the container width -->
                <div class="flex w-full transition-transform duration-300 ease-out"
                     style="@($"transform: translateX(-{currentCardIndex * 100}%)")">

                    @foreach (var enclosure in enclosures)
                    {
                        <!-- min-w-full resolves against the overflow container (block ancestor), not the flex parent -->
                        <div class="w-full shrink-0">
                            <div class="mx-auto px-4 sm:px-8">
                                <div class="rounded-2xl sm:rounded-3xl border border-slate-200 dark:border-slate-700 bg-white dark:bg-gray-900 shadow-xl sm:shadow-2xl overflow-hidden">

                                    <!-- Header bar -->
                                    <div class="flex items-center justify-between gap-2 px-4 sm:px-6 pt-4 sm:pt-6 pb-3">
                                        <div class="min-w-0 flex-1">
                                            <h2 class="text-lg sm:text-2xl font-bold text-slate-900 dark:text-white tracking-tight truncate">@enclosure.Name</h2>
                                            <p class="text-xs sm:text-sm text-slate-400 mt-0.5">@FormatEnclosureType(enclosure.EnclosureType)</p>
                                        </div>
                                        <button type="button"
                                                class="shrink-0 rounded-xl bg-green-600 hover:bg-green-700 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 shadow-md transition-colors whitespace-nowrap"
                                                @onclick="() => AddCritterToEnclosure(enclosure)">
                                            + Critter
                                        </button>
                                    </div>

                                    <!-- Critter canvas — full bleed, tall -->
                                    @{
                                        var enclosureCritters = critters.Where(r => r.EnclosureProfileId == enclosure.Id).ToList();
                                    }
                                    <div class="relative w-full overflow-hidden bg-gradient-to-b from-green-50 to-green-100 dark:from-green-950/30 dark:to-green-900/20 border-t border-green-100 dark:border-green-900"
                                         style="aspect-ratio: 2 / 1;">
                                        @if (enclosureCritters.Count == 0)
                                        {
                                            <div class="absolute inset-0 flex flex-col items-center justify-center gap-3 px-4 text-center">
                                                <p class="text-slate-400">No critters here yet.</p>
                                                <button type="button"
                                                        class="rounded-xl bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-5 py-2"
                                                        @onclick="() => AddCritterToEnclosure(enclosure)">
                                                    + Add one
                                                </button>
                                            </div>
                                        }
                                        @foreach (var critter in enclosureCritters)
                                        {
                                            <a href="@($"/critter/{critter.Id}")"
                                               class="absolute group focus:outline-none rounded-lg transition-transform hover:scale-110"
                                               style="top:@(GetCritterPosition(critter.Id).top)%; left:@(GetCritterPosition(critter.Id).left)%;">
                                                <img id="critter-@critter.Id"
                                                     src="@AppAssets.Resolve(critter.IconUrl)"
                                                     class="w-16 h-16 drop-shadow-lg"
                                                     alt="@critter.Name"/>
                                                <div class="absolute hidden sm:block opacity-0 group-hover:opacity-100 transition-opacity duration-200
                                                            bg-white text-slate-900 text-xs p-2.5 rounded-xl shadow-xl w-40 mt-2 z-10 pointer-events-none border border-slate-100
                                                            left-1/2 -translate-x-1/2">
                                                    <span class="font-semibold block text-sm">@critter.Name</span>
                                                    <span class="text-slate-500 text-xs">@critter.Species</span>
                                                    <span class="block mt-1 text-green-700 text-xs">Last fed: @(critter.LastFeedingDate?.ToShortDateString() ?? "—")</span>
                                                    <span class="text-green-600 font-medium text-xs mt-1 block">Tap to open →</span>
                                                </div>
                                            </a>
                                        }
                                    </div>

                                </div>
                            </div>
                        </div>
                    }

                    <!-- Final slide: Add critter / Add enclosure -->
                    <div class="min-w-full">
                        <div class="mx-auto px-4 sm:px-8">
                            <div class="rounded-3xl border-2 border-dashed border-green-200 dark:border-green-800 bg-green-50 dark:bg-green-950/20 flex flex-col items-center justify-center text-center gap-5"
                                 style="aspect-ratio: 2 / 1;">
                                <div>
                                    <h3 class="text-lg font-semibold text-slate-800">What would you like to add?</h3>
                                    <p class="text-sm text-slate-500 mt-1">Swipe back to browse your enclosures.</p>
                                </div>
                                <div class="flex flex-col gap-3 w-full max-w-xs">
                                    <button type="button"
                                            class="w-full rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 shadow-md transition-colors"
                                            @onclick="BeginPetFirstFlow">
                                        + Add critter
                                    </button>
                                    <button type="button"
                                            class="w-full rounded-xl bg-slate-100 border border-slate-300 hover:bg-slate-200 text-slate-800 font-semibold px-6 py-3 transition-colors"
                                            @onclick="ShowAddEnclosureModal">
                                        + Create enclosure
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Carousel dots -->
        @if (enclosures.Count > 0)
        {
            <nav class="flex items-center justify-center gap-2 mt-5" aria-label="Enclosure navigation">
                @for (int i = 0; i <= enclosures.Count; i++)
                {
                    int index = i;
                    bool isActive = index == currentCardIndex;
                    bool isAddSlide = i == enclosures.Count;
                    <button type="button"
                            aria-label="@(isAddSlide ? "Add" : enclosures[i].Name)"
                            class="@(isActive ? "w-3 h-3 rounded-full bg-green-600" : isAddSlide ? "w-2.5 h-2.5 rounded-full bg-green-200 border border-green-400" : "w-2.5 h-2.5 rounded-full bg-slate-300 hover:bg-slate-400") transition-all"
                            @onclick="() => NavigateToCard(index)">
                    </button>
                }
            </nav>
            @if (currentCardIndex == enclosures.Count)
            {
                <p class="text-center text-xs text-slate-400 mt-1">Swipe back to browse</p>
            }
        }

        </div><!-- end LEFT column -->

        <!-- RIGHT: Homeless critters sidebar -->
        @if (critters.Any(c => c.EnclosureProfileId == null))
        {
            <div class="mt-8 lg:mt-0 lg:w-72 lg:shrink-0">
                <div class="rounded-2xl border border-amber-200 bg-amber-50 dark:bg-amber-950/20 dark:border-amber-800 p-4">
                    <h2 class="text-sm font-semibold text-amber-900 dark:text-amber-200">Without an enclosure</h2>
                    <p class="text-xs text-amber-700 dark:text-amber-400 mt-0.5 mb-3">Assign a home or tap to view.</p>

                    <div class="space-y-3">
                        @foreach (var critter in critters.Where(c => c.EnclosureProfileId == null))
                        {
                            <div class="rounded-xl border border-amber-200 dark:border-amber-800 bg-white dark:bg-gray-900 p-3">
                                <div class="flex items-center gap-2.5 mb-2.5">
                                    <img src="@AppAssets.Resolve(critter.IconUrl)" alt="" class="w-10 h-10 rounded-lg shrink-0"/>
                                    <div class="min-w-0 flex-1">
                                        <p class="font-semibold text-slate-900 dark:text-white text-sm truncate">@critter.Name</p>
                                        <p class="text-xs text-slate-500 dark:text-slate-400 truncate">@critter.Species</p>
                                    </div>
                                    <a href="@($"/critter/{critter.Id}")"
                                       class="shrink-0 text-xs font-medium text-slate-500 hover:underline">
                                        View
                                    </a>
                                </div>

                                @if (enclosures.Count > 0)
                                {
                                    <div class="flex gap-2 min-w-0">
                                        <select value="@assignEnclosureIds.GetValueOrDefault(critter.Id, 0)"
                                                @onchange="e => SetAssignId(critter.Id, e)"
                                                class="flex-1 min-w-0 w-0 rounded-xl border border-slate-300 dark:border-slate-600 bg-white dark:bg-gray-800 px-2.5 py-1.5 text-xs text-slate-900 dark:text-white focus:outline-none focus:border-green-500 truncate">
                                            <option value="0">Pick enclosure…</option>
                                            @foreach (var enc in enclosures)
                                            {
                                                <option value="@enc.Id">@enc.Name</option>
                                            }
                                        </select>
                                        <button type="button"
                                                class="shrink-0 rounded-xl bg-green-600 hover:bg-green-700 text-white text-xs font-semibold px-3 py-1.5 transition-colors disabled:opacity-40 disabled:cursor-not-allowed whitespace-nowrap"
                                                disabled="@(assignEnclosureIds.GetValueOrDefault(critter.Id, 0) == 0)"
                                                @onclick="() => AssignCritterToEnclosureAsync(critter.Id)">
                                            Assign
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button type="button"
                                            class="w-full rounded-xl bg-green-600 hover:bg-green-700 text-white text-xs font-semibold px-3 py-1.5"
                                            @onclick="() => PromptEnclosureForCritter(critter)">
                                        + Create enclosure
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        </div><!-- end two-column flex -->
        </div><!-- end max-w-5xl -->
    }
</div>

<CreateEnclosureModal IsVisible="showEnclosureModal"
                      IsVisibleChanged="HandleEnclosureModalVisibilityChanged"
                      OnEnclosureCreated="HandleEnclosureCreated"/>

<AddCritterModal
    IsVisible="showCritterModal"
    IsVisibleChanged="HandleCritterModalVisibilityChanged"
    EnclosureName="@currentEnclosureName"
    EnclosureId="@currentEnclosureId"
    OnCritterAdded="HandleCritterAdded"/>

@code {
    private bool isLoading = true;
    private bool isAuthenticated;
    private List<EnclosureProfileDto> enclosures = new();
    private List<CritterDto> critters = new();
    private List<CritterDto> pendingCritters = new();
    private DotNetObjectReference<Dashboard>? dotNetHelper;
    private int currentCardIndex;
    private string? loadError;

    private bool showEnclosureModal;
    private bool showCritterModal;
    private string currentEnclosureName = "";
    private int currentEnclosureId;

    private Dictionary<int, int> assignEnclosureIds = new();
    private double _touchStartX;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isAuthenticated = await localStorage.ContainKeyAsync("authToken");
            if (isAuthenticated)
                await LoadData();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void PrevSlide() => NavigateToCard(currentCardIndex - 1);
    private void NextSlide() => NavigateToCard(currentCardIndex + 1);

    private void OnTouchStart(TouchEventArgs e) => _touchStartX = e.Touches[0].ClientX;

    private void OnTouchEnd(TouchEventArgs e)
    {
        var delta = _touchStartX - e.ChangedTouches[0].ClientX;
        int total = enclosures.Count + 1;
        if (delta > 50 && currentCardIndex < total - 1) currentCardIndex++;
        else if (delta < -50 && currentCardIndex > 0) currentCardIndex--;
        StateHasChanged();
    }

    private async Task HandleCritterAdded(CritterDto newCritter)
    {
        try
        {
            await LoadData();
            if (newCritter.EnclosureProfileId.HasValue)
            {
                int idx = enclosures.FindIndex(e => e.Id == newCritter.EnclosureProfileId.Value);
                if (idx >= 0) NavigateToCard(idx);
            }
            StateHasChanged();
        }
        catch
        {
            loadError = "Could not refresh after adding a critter. Try reloading.";
        }
    }

    private async Task LoadData()
    {
        loadError = null;
        try
        {
            enclosures = await EnclosureService.GetEnclosuresAsync();
            critters.Clear();
            assignEnclosureIds.Clear();

            foreach (var enc in enclosures)
                critters.AddRange(await CritterService.GetCrittersByEnclosureIdAsync(enc.Id));

            var unassigned = await CritterService.GetUnassignedCrittersAsync();
            critters.AddRange(unassigned);
            foreach (var c in unassigned)
                assignEnclosureIds.TryAdd(c.Id, 0);

            if (currentCardIndex > enclosures.Count)
                currentCardIndex = enclosures.Count;
        }
        catch (UnauthorizedAccessException)
        {
            loadError = "Your session may have expired. Please log in again.";
        }
        catch
        {
            loadError = "Could not load data. Check your connection and that the API is running.";
        }
    }

    private void NavigateToCard(int index)
    {
        int total = enclosures.Count + 1;
        if (index >= 0 && index < total)
        {
            currentCardIndex = index;
            StateHasChanged();
        }
    }

    private void ShowAddEnclosureModal() { showEnclosureModal = true; StateHasChanged(); }

    private Task HandleEnclosureModalVisibilityChanged(bool visible)
    {
        showEnclosureModal = visible;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task HandleEnclosureCreated(EnclosureProfileDto newEnclosure)
    {
        foreach (var draft in pendingCritters)
        {
            draft.EnclosureProfileId = newEnclosure.Id;
            await CritterService.CreateCritterAsync(draft);
        }
        pendingCritters.Clear();
        await LoadData();
        currentCardIndex = enclosures.FindIndex(e => e.Id == newEnclosure.Id);
        if (currentCardIndex < 0) currentCardIndex = Math.Max(0, enclosures.Count - 1);
        showEnclosureModal = false;
        StateHasChanged();
    }

    private void AddCritterToEnclosure(EnclosureProfileDto enclosure)
    {
        currentEnclosureName = enclosure.Name;
        currentEnclosureId = enclosure.Id;
        showCritterModal = true;
        StateHasChanged();
    }

    private void BeginPetFirstFlow()
    {
        currentEnclosureName = "";
        currentEnclosureId = 0;
        showCritterModal = true;
        StateHasChanged();
    }

    private Task HandleCritterModalVisibilityChanged(bool visible)
    {
        showCritterModal = visible;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void SetAssignId(int critterId, ChangeEventArgs e)
    {
        assignEnclosureIds[critterId] = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
    }

    private async Task AssignCritterToEnclosureAsync(int critterId)
    {
        if (!assignEnclosureIds.TryGetValue(critterId, out var enclosureId) || enclosureId == 0)
            return;
        var success = await CritterService.AssignEnclosureAsync(critterId, enclosureId);
        if (success) await LoadData();
        else loadError = "Could not assign enclosure. Try again.";
        StateHasChanged();
    }

    private void PromptEnclosureForCritter(CritterDto homelessCritter)
    {
        pendingCritters.Add(homelessCritter);
        showEnclosureModal = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            dotNetHelper = DotNetObjectReference.Create(this);

        if (!isLoading && isAuthenticated && enclosures.Count > 0 && currentCardIndex < enclosures.Count)
        {
            var ids = critters
                .Where(r => r.EnclosureProfileId == enclosures[currentCardIndex].Id)
                .Select(r => $"critter-{r.Id}")
                .ToArray();
            if (ids.Length > 0)
                await JSRuntime.InvokeVoidAsync("animateAllCritters", (object)ids);
        }
    }

    private static string FormatEnclosureType(EnclosureType t) => t switch
    {
        EnclosureType.RackSystem   => "Rack System",
        EnclosureType.FreeRoamRoom => "Free Roam Room",
        _                          => t.ToString()
    };

    private readonly Dictionary<int, (int top, int left)> _critterPositions = new();

    private (int top, int left) GetCritterPosition(int critterId)
    {
        if (!_critterPositions.TryGetValue(critterId, out var pos))
        {
            var rng = new Random(critterId);
            pos = (rng.Next(8, 72), rng.Next(8, 72));
            _critterPositions[critterId] = pos;
        }
        return pos;
    }
}
